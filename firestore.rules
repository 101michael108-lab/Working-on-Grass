
/**
 * # Firestore Security Rules
 *
 * ## Core Philosophy
 * This ruleset enforces a dual security model based on user ownership and role-based access control (RBAC).
 * Standard users have strict control over their own data, while a special 'admin' role is granted
 * broad read and management privileges over application-wide data like products, services, and user accounts.
 *
 * ## Data Structure
 * - `/users/{userId}`: Contains user profile data, including the critical 'role' field.
 * - `/users/{userId}/orders/...`: A subcollection tree containing a user's private order history.
 * - `/products`, `/services`, `/siteImages`: Top-level collections for publicly readable data, managed exclusively by admins.
 * - `/contactFormEntries`: A top-level "dropbox" collection, allowing anyone to write but only admins to read.
 * - `/mail`: Outgoing email queue for the Trigger Email extension.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user is the owner of a document
     * identified by the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if a document exists before an update or delete operation.
     */
    function isExistingDoc() {
        return resource != null;
    }

    /**
     * Checks if the authenticated user has the 'admin' role.
     * Uses a safe field access to prevent crashes if 'role' is missing.
     */
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    // ------------------------------------------------------------------
    // User Profiles (/users)
    // ------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && isExistingDoc() && request.resource.data.role == resource.data.role) || (isAdmin() && isExistingDoc());
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    // ------------------------------------------------------------------
    // Products (/products)
    // ------------------------------------------------------------------

    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      // Allow admins to update or allow automated stock reduction from the ITN route
      allow update: if (isAdmin() && isExistingDoc()) || 
                    (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
      allow delete: if isAdmin() && isExistingDoc();
    }

    // ------------------------------------------------------------------
    // Settings (/settings)
    // ------------------------------------------------------------------
    match /settings/config {
      allow get: if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Mail (/mail) - Trigger Email Extension
    // ------------------------------------------------------------------
    match /mail/{mailId} {
      // Only admins can read the mail logs.
      allow get, list: if isAdmin();
      // Allow anyone (including ITN route) to queue an email.
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Services (/services)
    // ------------------------------------------------------------------

    match /services/{serviceId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }

    // ------------------------------------------------------------------
    // Site Images (/siteImages)
    // ------------------------------------------------------------------

    match /siteImages/{siteImageId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() && isExistingDoc();
      allow delete: if isAdmin() && isExistingDoc();
    }
    
    // ------------------------------------------------------------------
    // Media Library (/mediaLibrary)
    // ------------------------------------------------------------------
    match /mediaLibrary/{mediaId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Contact Form Entries (/contactFormEntries)
    // ------------------------------------------------------------------

    match /contactFormEntries/{contactFormEntryId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if true;
      allow update: if false;
      allow delete: if isAdmin() && isExistingDoc();
    }

    // ------------------------------------------------------------------
    // Consultation Requests (/consultationRequests)
    // ------------------------------------------------------------------
    match /consultationRequests/{consultationRequestId} {
      allow get: if isAdmin();
      allow list: if isAdmin();
      allow create: if true;
      allow update: if false;
      allow delete: if isAdmin() && isExistingDoc();
    }

    // ------------------------------------------------------------------
    // User-Owned Data (/users/{userId}/...)
    // ------------------------------------------------------------------

    match /users/{userId} {
      match /orders/{orderId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        // Allow updates from owners (shipping info), admins (fulfillment), 
        // or the unauthenticated ITN route (status/paymentInfo).
        allow update: if (isAdmin() && isExistingDoc()) || 
                      (isOwner(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId) ||
                      (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paymentInfo']));
        allow delete: if isOwner(userId) || isAdmin();

        match /orderItems/{orderItemId} {
          allow get: if isOwner(userId) || isAdmin();
          allow list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) || isAdmin();
          allow update: if (isOwner(userId) || isAdmin()) && isExistingDoc();
          allow delete: if isOwner(userId) || isAdmin();
        }
      }
    }
    
    match /{path=**}/orders/{orderId} {
        allow list: if isAdmin();
    }
  }
}
