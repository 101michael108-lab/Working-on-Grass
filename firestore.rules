
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isExistingDoc() {
        return resource != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    // ------------------------------------------------------------------
    // User Profiles (/users)
    // ------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && isExistingDoc() && request.resource.data.role == resource.data.role) || (isAdmin() && isExistingDoc());
      allow delete: if isOwner(userId) && isExistingDoc();
    }

    // ------------------------------------------------------------------
    // Products (/products)
    // ------------------------------------------------------------------

    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isAdmin();
      // Allow admins to update or allow automated stock reduction from the ITN route (unauthenticated)
      allow update: if (isAdmin() && isExistingDoc()) || 
                    (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock']));
      allow delete: if isAdmin() && isExistingDoc();
    }

    // ------------------------------------------------------------------
    // Site Media & Images
    // ------------------------------------------------------------------
    match /siteImages/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /mediaLibrary/{imageId} {
      allow read, write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Resources (/resources)
    // ------------------------------------------------------------------
    match /resources/{resourceId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Settings (/settings)
    // ------------------------------------------------------------------
    match /settings/config {
      allow get: if true;
      allow write: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Mail (/mail) - Trigger Email Extension
    // ------------------------------------------------------------------
    match /mail/{mailId} {
      allow get, list: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // Leads & Inquiries
    // ------------------------------------------------------------------
    match /contactFormEntries/{id} {
      allow get, list: if isAdmin();
      allow create: if true;
      allow delete: if isAdmin();
    }

    match /consultationRequests/{id} {
      allow get, list: if isAdmin();
      allow create: if true;
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // User-Owned Data (/users/{userId}/...)
    // ------------------------------------------------------------------

    match /users/{userId} {
      match /orders/{orderId} {
        allow get: if isOwner(userId) || isAdmin();
        allow list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if (isAdmin() && isExistingDoc()) || 
                      (isOwner(userId) && isExistingDoc() && request.resource.data.userId == resource.data.userId) ||
                      (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paymentInfo']));
        allow delete: if isOwner(userId) || isAdmin();

        match /orderItems/{orderItemId} {
          allow get, list: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) || isAdmin();
          allow update: if (isOwner(userId) || isAdmin()) && isExistingDoc();
          allow delete: if isOwner(userId) || isAdmin();
        }
      }
    }
    
    // Collection Group Access for Orders (Public Tracking & Admin List)
    match /{path=**}/orders/{orderId} {
        // Allow list for admins
        // Allow list for public order status lookup IF strictly limited and email is provided
        allow list: if isAdmin() || (request.query.limit <= 10 && request.query.filters.size() >= 1);
        // Allow get for anyone if they have the specific orderId
        allow get: if true; 
    }
  }
}
